{
  "name": "@planvokter/riotplan-templates",
  "version": "1.1.2",
  "description": "Plan templates for RiotPlan - starter templates for common plan types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run lint && vite build",
    "test": "npm run test:coverage",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --run --coverage --reporter verbose",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "precommit": "npm run build && npm run lint && npm run test",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "riotplan",
    "templates",
    "plan",
    "starter"
  ],
  "author": "Tim O'Brien <tobrien@discursive.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/planvokter/riotplan",
    "directory": "packages/riotplan-templates"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.28.0",
    "@types/node": "^24.10.9",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
