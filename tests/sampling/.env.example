# API Keys for FastMCP Testing
# Copy this file to .env and add your keys

# OpenAI API Key (for testing with OpenAI handler)
OPENAI_API_KEY=sk-...

# Anthropic API Key (for testing with Anthropic handler)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override default models
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-5
